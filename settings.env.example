# Скопируйте в settings.env. Чат — через Ollama; фото — models/vision (см. README).
# Подробные логи в консоль: HEALTHAI_DEBUG=1

# Внешние API (опционально)
EDAMAM_APP_ID=
EDAMAM_APP_KEY=
USDA_API_KEY=
SPOONACULAR_API_KEY=

# Путь к весам распознавания еды (необязательно)
# HEALTHAI_FOOD_MODEL_PATH=/полный/путь/к/resnet50.pth

# Ollama: при первом запуске setup/launch всё настраивается само; ниже — необязательные переопределения.
# Отключить генерацию: HEALTHAI_OLLAMA_ENABLED=0
HEALTHAI_OLLAMA_ENABLED=1
HEALTHAI_OLLAMA_HOST=http://127.0.0.1:11435
HEALTHAI_OLLAMA_MODEL=qwen2.5:3b
HEALTHAI_OLLAMA_TIMEOUT=120
# Температура только для чата (0.1–1.2): ниже — меньше случайных иероглифов/LaTeX у мультиязычных моделей; по умолчанию 0.52
# HEALTHAI_OLLAMA_CHAT_TEMPERATURE=0.45
